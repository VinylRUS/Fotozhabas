// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Telegram user who submits posts
model TelegramUser {
  id            String   @id @default(cuid())
  telegramId    String   @unique
  username      String?
  firstName     String?
  lastName      String?
  trustLevel    Int      @default(0)  // 0=new, 1=normal, 2=trusted
  postsCount    Int      @default(0)
  acceptedCount Int      @default(0)
  rejectedCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  posts      Post[]
  moderator  Moderator?
}

// Content types for posts
enum PostType {
  PHOTO
  YOUTUBE
  TEXT
}

// Post status lifecycle
enum PostStatus {
  PENDING
  APPROVED
  REJECTED
  POSTED
  DEFERRED
}

model Post {
  id              String     @id @default(cuid())
  type            PostType
  status          PostStatus @default(PENDING)
  text            String?
  mediaUrl        String?    // URL to photo/file
  mediaFileId     String?    // Telegram file_id for downloading
  youtubeUrl      String?
  youtubeTitle    String?
  youtubeThumbnail String?  // YouTube thumbnail URL
  authorId        String
  author          TelegramUser @relation(fields: [authorId], references: [id], onDelete: Cascade)
  channelId       String?    // Which channel to post to (null = default)
  channel         Channel?   @relation(fields: [channelId], references: [id])
  reviewedAt      DateTime?
  reviewerId      String?    // Who reviewed (moderator/streamer)
  postedAt        DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  voteSessions VoteSession[]
}

// Telegram channels where posts get published
model Channel {
  id          String  @id @default(cuid())
  telegramId  String  @unique  // @channel_username or numeric ID
  name        String
  isDefault   Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts Post[]
}

// Moderators with roles
enum ModeratorRole {
  ADMIN
  MODERATOR
}

model Moderator {
  id        String         @id @default(cuid())
  userId    String         @unique
  user      TelegramUser   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      ModeratorRole  @default(MODERATOR)
  addedById String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

// Vote session status
enum VoteSessionStatus {
  ACTIVE
  CLOSED
}

// Final decision for vote
enum VoteDecision {
  POSTED
  SKIPPED
}

model VoteSession {
  id                  String           @id @default(cuid())
  postId              String
  post                Post             @relation(fields: [postId], references: [id], onDelete: Cascade)
  status              VoteSessionStatus @default(ACTIVE)
  startedAt           DateTime         @default(now())
  closedAt            DateTime?
  durationSec         Int              @default(30)
  votesFor            Int              @default(0)
  votesAgainst        Int              @default(0)
  finalDecision       VoteDecision?
  streamerFollowedChat Boolean?
  totalVoters         Int              @default(0)

  votes Vote[]
}

// Individual votes from Twitch/GoodGame
enum VotePlatform {
  TWITCH
  GOODGAME
}

model Vote {
  id          String        @id @default(cuid())
  sessionId   String
  session     VoteSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  platformId  String        // User ID on the platform
  platform    VotePlatform
  vote        Int           // 1 = FOR, 2 = AGAINST
  votedAt     DateTime      @default(now())

  @@unique([sessionId, platformId, platform])  // One vote per user per session
}

// Flexible key-value settings
model Setting {
  key       String  @id
  value     String
  updatedAt DateTime @updatedAt
}
